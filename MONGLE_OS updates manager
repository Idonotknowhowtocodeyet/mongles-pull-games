<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>MONGLE_OS // ARCHIVE_MANAGER</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
        :root { --primary: #00ff41; --bg: #050505; --card: #0f0f0f; --text-dim: #555; --warn: #ffae00; --danger: #ff0000;}
        body { background: var(--bg); color: var(--primary); font-family: 'Share Tech Mono', monospace; padding: 50px 20px; display: flex; flex-direction: column; align-items: center; margin: 0; }
        
        /* Timeline Styles */
        .timeline { position: relative; max-width: 700px; width: 100%; border-left: 2px solid #1a1a1a; padding-left: 40px; margin-top: 20px; }
        .header { width: 100%; max-width: 700px; margin-bottom: 20px; border-bottom: 1px solid var(--primary); padding-bottom: 10px; }
        .v-card { background: var(--card); border: 1px solid #222; margin-bottom: 30px; padding: 20px; border-radius: 8px; position: relative; transition: 0.3s; }
        .v-card:hover { border-color: var(--primary); transform: translateX(5px); box-shadow: 0 0 15px rgba(0,255,65,0.1); }
        .v-card::before { content: ''; position: absolute; left: -47px; top: 25px; width: 12px; height: 12px; background: var(--bg); border: 2px solid var(--primary); border-radius: 50%; }
        .v-name { font-size: 22px; color: #fff; display: block; text-transform: uppercase; }
        .v-desc { color: #888; font-size: 14px; margin: 10px 0; line-height: 1.4; }
        .v-date { font-size: 10px; color: var(--text-dim); text-transform: uppercase; }
        
        .btn { display: inline-block; margin-top: 15px; padding: 8px 20px; background: transparent; border: 1px solid var(--primary); color: var(--primary); text-decoration: none; font-size: 12px; transition: 0.2s; cursor: pointer; font-family: inherit; }
        .btn:hover { background: var(--primary); color: #000; }
        .btn-warn { border-color: var(--warn); color: var(--warn); }
        .btn-warn:hover { background: var(--warn); color: #000; }
        .btn-danger { border-color: var(--danger); color: var(--danger); }
        .btn-danger:hover { background: var(--danger); color: #fff; }

        /* Admin Modal Styles */
        #adminModal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 9999; justify-content: center; align-items: center; padding: 20px; }
        .admin-content { background: #0a0a0a; border: 1px solid var(--warn); width: 100%; max-width: 800px; max-height: 90vh; overflow-y: auto; padding: 25px; border-radius: 8px; box-shadow: 0 0 30px rgba(255, 174, 0, 0.1); }
        .admin-header { display: flex; justify-content: space-between; border-bottom: 1px solid #333; padding-bottom: 15px; margin-bottom: 20px; color: var(--warn); }
        
        .input-group { margin-bottom: 15px; }
        .input-group label { display: block; font-size: 10px; color: #888; margin-bottom: 5px; letter-spacing: 1px; }
        .input-box { width: 100%; background: #000; border: 1px solid #333; color: #fff; padding: 10px; font-family: inherit; box-sizing: border-box; border-radius: 4px; }
        .input-box:focus { border-color: var(--warn); outline: none; }
        
        .admin-list-item { background: #000; border: 1px solid #222; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
        .admin-list-item strong { color: #fff; }
    </style>
</head>
<body>

    <div class="header">
        <h1>PROJECT_EVOLUTION</h1>
        <div style="font-size: 10px; opacity: 0.5;">welcome this is the evolution of mongle from the beginning to the end</div>
        <p style="font-size: 11px; color: #555; margin-top: 10px;">TIMELINE REVERSED: NEWEST CORE INITIALIZED AT TOP</p>
    </div>

    <div class="timeline" id="timeline">
        </div>

    <div id="adminModal">
        <div class="admin-content">
            <div class="admin-header">
                <h2 style="margin: 0; letter-spacing: 3px;">⚡ MONGLE OVERSEER CATALOG</h2>
                <button class="btn btn-warn" style="margin: 0;" onclick="closeAdmin()">CLOSE X</button>
            </div>

            <div style="display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 300px; background: #111; padding: 20px; border: 1px solid #222; border-radius: 6px;">
                    <h3 style="margin-top: 0; color: var(--warn); font-size: 14px;" id="formTitle">ADD NEW VERSION</h3>
                    <input type="hidden" id="editId">
                    
                    <div class="input-group">
                        <label>GITHUB FILENAME (e.g. v9.html)</label>
                        <input type="text" id="inpFileName" class="input-box" placeholder="v9.html">
                    </div>
                    <div class="input-group">
                        <label>DISPLAY NAME</label>
                        <input type="text" id="inpDisplayName" class="input-box" placeholder="MONGLE_OS v9">
                    </div>
                    <div class="input-group">
                        <label>DATE / MILESTONE</label>
                        <input type="text" id="inpDate" class="input-box" placeholder="MARCH 20">
                    </div>
                    <div class="input-group">
                        <label>CHANGELOG DESCRIPTION</label>
                        <textarea id="inpDesc" class="input-box" style="height: 80px; resize: vertical;" placeholder="What did you add?"></textarea>
                    </div>

                    <button class="btn btn-warn" style="width: 100%;" onclick="saveEntry()">SAVE DATA TO SYSTEM</button>
                    <button class="btn" style="width: 100%; display: none;" id="cancelEditBtn" onclick="resetForm()">CANCEL EDIT</button>
                </div>

                <div style="flex: 1; min-width: 300px;">
                    <h3 style="margin-top: 0; color: #888; font-size: 14px;">CURRENT DATABASE (Oldest to Newest)</h3>
                    <div id="adminEntryList" style="max-height: 400px; overflow-y: auto;">
                        </div>
                </div>
            </div>
        </div>
    </div>

<script>
    // --- GITHUB CONFIG ---
    const GITHUB_CONFIG = {
        user: 'Idonotknowhowtocodeyet',
        repo: 'turbo-octo-barnacle',
        branch: 'main'
    };

    // --- DATABASE INITIALIZATION ---
    // Here are your custom names, dates, and highly accurate descriptions
    const defaultData = [
        { 
            id: 1, 
            fileName: "tech work Feb 23 better.html", 
            displayName: "v6 MONGLE_OS", 
            description: "The original 404-themed OS. Features the ghost-corner login, basic game grid, and the first iteration of panic triggers.", 
            date: "MARCH 2" 
        },
        { 
            id: 2, 
            fileName: "v7 thets go.html", 
            displayName: "v7 MONGLE_OS", 
            description: "The 'Thets Go' update. Introduced the Overseer panel, live presence tracking, and global nuke/freeze commands.", 
            date: "MARCH 5" 
        },
        { 
            id: 3, 
            fileName: "v8 bru.html", 
            displayName: "MONGLE_OS v8", 
            description: "The massive Cyberpunk update. Added the Matrix lockdown, 50+ mega pranks, live chat with reactions, and the achievement system.", 
            date: "MARCH 17" 
        }
    ];

    // Using a new DB key so it immediately overwrites any old testing cache
    if (!localStorage.getItem('mongle_archive_db_v2')) {
        localStorage.setItem('mongle_archive_db_v2', JSON.stringify(defaultData));
    }

    function getDB() {
        return JSON.parse(localStorage.getItem('mongle_archive_db_v2')) || [];
    }

    function setDB(data) {
        localStorage.setItem('mongle_archive_db_v2', JSON.stringify(data));
        renderTimeline();
        renderAdminList();
    }

    // --- MAIN RENDER LOGIC ---
    function renderTimeline() {
        const container = document.getElementById('timeline');
        container.innerHTML = '';
        const data = getDB();

        // Create a reversed copy so the newest entry is at the top
        const reversedData = [...data].reverse();

        reversedData.forEach(version => {
            const githack = `https://raw.githack.com/${GITHUB_CONFIG.user}/${GITHUB_CONFIG.repo}/${GITHUB_CONFIG.branch}/${version.fileName}`;
            
            const card = document.createElement('div');
            card.className = 'v-card';
            card.innerHTML = `
                <span class="v-date">${version.date}</span>
                <span class="v-name">${version.displayName}</span>
                <p class="v-desc">${version.description}</p>
                <a href="${githack}" target="_blank" class="btn">INITIALIZE_BOOT</a>
            `;
            container.appendChild(card);
        });
    }

    // --- ADMIN PANEL LOGIC ---
    function checkAdmin() {
        const pass = prompt("AUTH_CODE REQUIRED:");
        if (pass === "MONGLE_OWNER") {
            document.getElementById('adminModal').style.display = 'flex';
            renderAdminList();
        } else if (pass) {
            alert("ACCESS DENIED");
        }
    }

    function closeAdmin() {
        document.getElementById('adminModal').style.display = 'none';
        resetForm();
    }

    function renderAdminList() {
        const list = document.getElementById('adminEntryList');
        list.innerHTML = '';
        const data = getDB();

        data.forEach(entry => {
            const el = document.createElement('div');
            el.className = 'admin-list-item';
            el.innerHTML = `
                <div>
                    <strong>${entry.displayName}</strong><br>
                    <span style="font-size: 10px; color: #666;">${entry.fileName}</span>
                </div>
                <div style="display:flex; gap: 5px;">
                    <button class="btn btn-warn" style="margin: 0; padding: 5px 10px;" onclick="editEntry(${entry.id})">EDIT</button>
                    <button class="btn btn-danger" style="margin: 0; padding: 5px 10px;" onclick="deleteEntry(${entry.id})">X</button>
                </div>
            `;
            list.appendChild(el);
        });
    }

    function saveEntry() {
        const id = document.getElementById('editId').value;
        const fileName = document.getElementById('inpFileName').value.trim();
        const displayName = document.getElementById('inpDisplayName').value.trim();
        const date = document.getElementById('inpDate').value.trim();
        const desc = document.getElementById('inpDesc').value.trim();

        if (!fileName || !displayName) return alert("Filename and Display Name are required.");

        let data = getDB();

        if (id) {
            // Update existing
            const index = data.findIndex(e => e.id == id);
            if (index > -1) {
                data[index] = { id: parseInt(id), fileName, displayName, date, description: desc };
            }
        } else {
            // Add new
            const newId = data.length > 0 ? Math.max(...data.map(e => e.id)) + 1 : 1;
            data.push({ id: newId, fileName, displayName, date, description: desc });
        }

        setDB(data);
        resetForm();
    }

    function editEntry(id) {
        const data = getDB();
        const entry = data.find(e => e.id == id);
        if (!entry) return;

        document.getElementById('formTitle').innerText = "EDITING RECORD: " + entry.displayName;
        document.getElementById('editId').value = entry.id;
        document.getElementById('inpFileName').value = entry.fileName;
        document.getElementById('inpDisplayName').value = entry.displayName;
        document.getElementById('inpDate').value = entry.date;
        document.getElementById('inpDesc').value = entry.description;
        
        document.getElementById('cancelEditBtn').style.display = 'inline-block';
    }

    function deleteEntry(id) {
        if (!confirm("Are you sure you want to permanently delete this record?")) return;
        let data = getDB();
        data = data.filter(e => e.id != id);
        setDB(data);
    }

    function resetForm() {
        document.getElementById('formTitle').innerText = "ADD NEW VERSION";
        document.getElementById('editId').value = '';
        document.getElementById('inpFileName').value = '';
        document.getElementById('inpDisplayName').value = '';
        document.getElementById('inpDate').value = '';
        document.getElementById('inpDesc').value = '';
        document.getElementById('cancelEditBtn').style.display = 'none';
    }

    // --- KEYBOARD LISTENERS ---
    window.addEventListener('keydown', (e) => {
        if (e.shiftKey && (e.key === 'L' || e.key === 'l')) {
            e.preventDefault();
            checkAdmin();
        }
    });

    // Boot OS
    renderTimeline();

</script>
</body>
</html>
